---
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <p class="footer-text">&copy; 2026 <span class="footer-dot"></span> Sami Syverson</p>
      <p class="footer-tag" id="footer-tag">
        "If Sami don't trust the pull req', I'm gon' purge it."
      </p>
    </div>
  </div>
</footer>

<script>
  const tag = document.getElementById('footer-tag');
  if (tag && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    tag.style.opacity = '1';
    setTimeout(() => {
      tag.style.transition = 'opacity 0.8s ease';
      tag.style.opacity = '0';
    }, 3000);
  } else if (tag) {
    tag.style.opacity = '0.4';
  }
</script>

<style is:global>
  .footer {
    border-top: 1px solid var(--color-border-subtle);
    padding: 3rem 0;
    position: relative;
    z-index: 1;
  }
  .footer-inner {
    text-align: center;
  }
  .footer-text {
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }
  .footer-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent-primary);
    box-shadow: 0 0 6px var(--color-accent-glow);
    margin: 0 4px;
    vertical-align: middle;
    animation: footer-pulse 2s ease-in-out infinite;
  }
  @keyframes footer-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.6); }
  }
  .footer-tag {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: var(--type-xs);
    color: var(--color-text-muted);
    opacity: 1;
    margin-top: var(--space-sm);
  }
</style>
