---
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <p class="footer-text">
        <span class="footer-copyright">&copy; 2026</span>
        <span class="footer-separator" aria-hidden="true">//</span>
        <span class="footer-author">Sami Syverson</span>
      </p>
      <p class="footer-tag" id="footer-tag">
        <span class="footer-tag-text">"If Sami don't trust the pull req', I'm gon' purge it."</span>
        <span class="footer-tag-label">PROD</span>
      </p>
    </div>
  </div>
</footer>

<script>
  const tag = document.getElementById('footer-tag');
  if (tag && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    tag.style.opacity = '1';
    setTimeout(() => {
      tag.style.transition = 'opacity 0.8s ease';
      tag.style.opacity = '0.65';
    }, 3000);
  } else if (tag) {
    tag.style.opacity = '0.7';
  }
</script>

<style is:global>
  .footer {
    border-top: 1px solid var(--color-border-subtle);
    padding: 3rem 0;
    position: relative;
    z-index: 1;
  }
  .footer-inner {
    text-align: center;
  }
  .footer-text {
    font-family: var(--font-mono);
    font-size: var(--type-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
  }
  .footer-separator {
    opacity: 0.2;
    font-size: 10px;
  }
  .footer-author {
    color: var(--color-text-body);
  }
  .footer-tag {
    font-family: var(--font-mono);
    font-style: italic;
    font-size: var(--type-xs);
    color: var(--color-text-muted);
    opacity: 1;
    margin-top: var(--space-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
  }
  .footer-tag-text {
    font-style: italic;
  }
  .footer-tag-label {
    font-style: normal;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 1px 6px;
    border: 1px solid rgba(255, 59, 140, 0.25);
    border-radius: var(--radius-sm);
    color: var(--color-accent-primary);
    opacity: 0.6;
  }
</style>
